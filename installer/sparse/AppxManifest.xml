<?xml version="1.0" encoding="utf-8"?>
<!--
  Shortcut Icon Changer - Windows 11 モダン コンテキスト メニュー用 sparse manifest (本番)。
  PowerToys の出荷マニフェスト構造に準拠。

  - desktop4/desktop5: .lnk(Type="*" + ハンドラの GetState で .lnk 限定)へモダン メニュー項目を追加
  - com:SurrogateServer: in-proc COM (Sic.ShellExt.dll) を dllhost サロゲートで起動
  - AllowExternalContent=true: パッケージ本体(exe/dll/assets)は MSI 導入先に置き、
    Add-AppxPackage -ExternalLocation <installdir> で外部参照する(sparse パッケージ)
  - 配布は自己署名 .msix。Version は Build-Sparse.ps1 が __VERSION__ を実値へ置換する。
  - Publisher は署名証明書のサブジェクト(CN=kemaruya)と完全一致が必須。
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  IgnorableNamespaces="uap uap10 rescap desktop4 desktop5 com">

  <Identity Name="kemaruya.ShortcutIconChanger"
            ProcessorArchitecture="x64"
            Publisher="CN=kemaruya"
            Version="__VERSION__" />

  <Properties>
    <DisplayName>Shortcut Icon Changer</DisplayName>
    <PublisherDisplayName>kemaruya</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="unvirtualizedResources" />
  </Capabilities>

  <Applications>
    <Application Id="SicContextMenu"
                 Executable="ShortcutIconChanger.exe"
                 uap10:TrustLevel="mediumIL"
                 uap10:RuntimeBehavior="win32App">
      <uap:VisualElements AppListEntry="none"
                          DisplayName="Shortcut Icon Changer"
                          Description="Change shortcut (.lnk) icon"
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\Square150x150Logo.png"
                          Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="*">
              <desktop5:Verb Id="ChangeIcon" Clsid="B6E6D7EA-EEBA-4B94-84CE-E34DCF06AD5C" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
        <com:Extension Category="windows.comServer" uap10:RuntimeBehavior="packagedClassicApp">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Shortcut Icon Changer context menu handler">
              <com:Class Id="B6E6D7EA-EEBA-4B94-84CE-E34DCF06AD5C"
                         Path="Sic.ShellExt.dll"
                         ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
