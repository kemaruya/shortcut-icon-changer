<Window x:Class="Sic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Sic.App"
        xmlns:vm="clr-namespace:Sic.App.ViewModels"
        Title="{Binding Strings.WindowTitle}"
        Height="740" Width="1000" MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Yu Gothic UI, Segoe UI, Meiryo UI"
        FontSize="13" Background="#F3F3F3"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <local:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
        <local:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVis" />

        <!-- タグ チップ（ToggleButton） -->
        <Style x:Key="ChipStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Foreground" Value="#202020" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="12" Background="#ECECEC"
                                BorderBrush="#DADADA" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E0E0E0" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0067C0" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0067C0" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 通常チップ（スタイル/ジャンル） -->
        <DataTemplate x:Key="ChipTemplate" DataType="{x:Type vm:ChipVM}">
            <ToggleButton Style="{StaticResource ChipStyle}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          FontSize="{Binding FontSize}"
                          Content="{Binding Display}" />
        </DataTemplate>

        <!-- 色調チップ（色見本付き） -->
        <DataTemplate x:Key="ColorChipTemplate" DataType="{x:Type vm:ChipVM}">
            <ToggleButton Style="{StaticResource ChipStyle}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          FontSize="{Binding FontSize}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="11" Height="11" Margin="0,0,6,0"
                             Stroke="#80000000" StrokeThickness="0.5"
                             Fill="{Binding Swatch}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
                </StackPanel>
            </ToggleButton>
        </DataTemplate>

        <!-- アイコン タイル -->
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Width" Value="98" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0067C0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TileTemplate" DataType="{x:Type vm:IconTileVM}">
            <Button Style="{StaticResource TileButton}"
                    Command="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Item}"
                    ToolTip="{Binding DisplayName}">
                <StackPanel>
                    <Image Source="{Binding Thumbnail}" Width="48" Height="48"
                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="{Binding DisplayName}" TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" TextWrapping="Wrap"
                               MaxHeight="32" Margin="0,4,0,0" FontSize="11" />
                </StackPanel>
            </Button>
        </DataTemplate>

        <!-- 仮想化リストの 1 行（横並びタイル。万一の幅誤差は WrapPanel が吸収） -->
        <DataTemplate x:Key="RowTemplate" DataType="{x:Type vm:TileRow}">
            <ItemsControl ItemsSource="{Binding Tiles}" ItemTemplate="{StaticResource TileTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>

        <!-- 行コンテナ: ListBoxItem の選択ハイライト/余白を除去（見た目はプレーンな行） -->
        <Style x:Key="RowContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダー: 絞り込みラベル + 検索ボックス + 言語 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding Strings.FilterLabel}"
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />

            <Grid Grid.Column="1">
                <TextBox x:Name="SearchBox" Padding="7,5" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=120}" />
                <TextBlock Text="{Binding Strings.SearchPlaceholder}" Foreground="#9AA0A6"
                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding SearchText, Converter={StaticResource EmptyToVis}}" />
            </Grid>

            <TextBlock Grid.Column="2" Text="{Binding Strings.LanguageLabel}"
                       VerticalAlignment="Center" Margin="16,0,6,0" />
            <ComboBox Grid.Column="3" Width="116" SelectedIndex="{Binding LanguageChoice, Mode=TwoWay}">
                <ComboBoxItem Content="{Binding Strings.LangAuto}" />
                <ComboBoxItem Content="{Binding Strings.LangJa}" />
                <ComboBoxItem Content="{Binding Strings.LangEn}" />
            </ComboBox>
        </Grid>

        <!-- 注記（ショートカット未指定時のみ） -->
        <Border Grid.Row="1" Background="#FFF4E5" BorderBrush="#F0C77A" BorderThickness="1"
                CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                Visibility="{Binding NoteText, Converter={StaticResource NonEmptyToVis}}">
            <TextBlock Text="{Binding NoteText}" Foreground="#8A5A00" TextWrapping="Wrap" />
        </Border>

        <!-- ファセット タグ クラウド -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E2E2" BorderThickness="1"
                CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="{Binding Strings.StyleFacet}" DockPanel.Dock="Left"
                               Width="68" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,5,4,0" />
                    <ItemsControl ItemsSource="{Binding Styles}" ItemTemplate="{StaticResource ChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <DockPanel Margin="0,2">
                    <TextBlock Text="{Binding Strings.GenreFacet}" DockPanel.Dock="Left"
                               Width="68" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,5,4,0" />
                    <ItemsControl ItemsSource="{Binding Genres}" ItemTemplate="{StaticResource ChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <DockPanel Margin="0,2,0,0">
                    <TextBlock Text="{Binding Strings.ColorFacet}" DockPanel.Dock="Left"
                               Width="68" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,5,4,0" />
                    <ItemsControl ItemsSource="{Binding Colors}" ItemTemplate="{StaticResource ColorChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <Button Content="{Binding Strings.ClearTags}" Command="{Binding ClearTagsCommand}"
                        HorizontalAlignment="Left" Margin="68,8,0,0" Padding="10,4" />
            </StackPanel>
        </Border>

        <!-- アイコン グリッド（行単位で仮想化。可視行のタイルのみデコード） -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E2E2" BorderThickness="1" CornerRadius="8">
            <ListBox x:Name="IconList" ItemsSource="{Binding Rows}"
                     BorderThickness="0" Background="Transparent" Padding="6"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ItemContainerStyle="{StaticResource RowContainerStyle}"
                     ItemTemplate="{StaticResource RowTemplate}"
                     SizeChanged="IconList_SizeChanged" />
        </Border>

        <!-- フッター -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="{Binding CountText}" VerticalAlignment="Center" Foreground="#606060" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding Strings.ResetToDefault}" Command="{Binding ResetCommand}"
                        Padding="12,6" Margin="0,0,8,0" />
                <Button Content="{Binding Strings.Custom}" Command="{Binding CustomCommand}"
                        Padding="12,6" Margin="0,0,8,0" />
                <Button x:Name="CancelButton" Content="{Binding Strings.Cancel}" Click="CancelButton_Click"
                        Padding="12,6" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
