<Window x:Class="Sic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Sic.App"
        xmlns:vm="clr-namespace:Sic.App.ViewModels"
        Title="{Binding Strings.WindowTitle}"
        Height="740" Width="1000" MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Yu Gothic UI, Segoe UI, Meiryo UI"
        FontSize="13"
        Background="{DynamicResource Sic.Window}" Foreground="{DynamicResource Sic.Text}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <!-- タグ チップ（ToggleButton） -->
        <Style x:Key="ChipStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource Sic.ChipText}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="12" Background="{DynamicResource Sic.ChipBg}"
                                BorderBrush="{DynamicResource Sic.ChipBorder}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Sic.ChipBgHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Sic.Accent}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Sic.Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource Sic.AccentText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 通常チップ（スタイル/ジャンル） -->
        <DataTemplate x:Key="ChipTemplate" DataType="{x:Type vm:ChipVM}">
            <ToggleButton Style="{StaticResource ChipStyle}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Content="{Binding Display}" />
        </DataTemplate>

        <!-- 色調チップ（色見本付き） -->
        <DataTemplate x:Key="ColorChipTemplate" DataType="{x:Type vm:ChipVM}">
            <ToggleButton Style="{StaticResource ChipStyle}"
                          IsChecked="{Binding IsChecked, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="11" Height="11" Margin="0,0,6,0"
                             Stroke="#80000000" StrokeThickness="0.5"
                             Fill="{Binding Swatch}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
                </StackPanel>
            </ToggleButton>
        </DataTemplate>

        <!-- アイコン タイル -->
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Width" Value="98" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Sic.Text}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Sic.TileHover}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Sic.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TileTemplate" DataType="{x:Type vm:IconTileVM}">
            <Button Style="{StaticResource TileButton}"
                    Command="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Item}"
                    ToolTip="{Binding DisplayName}">
                <StackPanel>
                    <Image Source="{Binding Thumbnail}" Width="48" Height="48"
                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="{Binding DisplayName}" TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" TextWrapping="Wrap"
                               MaxHeight="32" Margin="0,4,0,0" FontSize="11" />
                </StackPanel>
            </Button>
        </DataTemplate>

        <!-- 仮想化リストの 1 行（横並びタイル。万一の幅誤差は WrapPanel が吸収） -->
        <DataTemplate x:Key="RowTemplate" DataType="{x:Type vm:TileRow}">
            <ItemsControl ItemsSource="{Binding Tiles}" ItemTemplate="{StaticResource TileTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>

        <!-- 行コンテナ: ListBoxItem の選択ハイライト/余白を除去（見た目はプレーンな行） -->
        <Style x:Key="RowContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 対象ショートカット バー: どの .lnk のアイコンを変えるか + 現在のアイコン -->
        <Border Grid.Row="0" Background="{DynamicResource Sic.Panel}" BorderBrush="{DynamicResource Sic.PanelBorder}"
                BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 現在のアイコン プレビュー（未選択時は "?"） -->
                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6"
                        Background="{DynamicResource Sic.ControlBg}" BorderBrush="{DynamicResource Sic.ControlBorder}"
                        BorderThickness="1" Margin="0,0,12,0">
                    <Grid>
                        <Image Source="{Binding CurrentIcon}" Width="32" Height="32"
                               Visibility="{Binding HasTarget, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="?" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Sic.Subtle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding HasTarget, Converter={StaticResource InvBoolToVis}}" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Strings.TargetLabel}" FontSize="11"
                               Foreground="{DynamicResource Sic.TextSecondary}" />
                    <TextBlock Text="{Binding TargetName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding TargetPath}" />
                </StackPanel>

                <Button Grid.Column="2" Content="{Binding ChooseTargetLabel}" Command="{Binding ChooseTargetCommand}"
                        VerticalAlignment="Center" Padding="12,6" />
            </Grid>
        </Border>

        <!-- ヘッダー: 絞り込みラベル + 検索ボックス + 言語 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding Strings.FilterLabel}"
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />

            <Grid Grid.Column="1">
                <TextBox x:Name="SearchBox" Padding="7,5" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=120}" />
                <TextBlock Text="{Binding Strings.SearchPlaceholder}" Foreground="{DynamicResource Sic.Subtle}"
                           Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding SearchText, Converter={StaticResource EmptyToVis}}" />
            </Grid>

            <TextBlock Grid.Column="2" Text="{Binding Strings.LanguageLabel}"
                       VerticalAlignment="Center" Margin="16,0,6,0" />
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton Style="{StaticResource SegmentStyle}" GroupName="Lang"
                             Content="{Binding Strings.LangAuto}"
                             IsChecked="{Binding LanguageChoice, Converter={StaticResource EqBool}, ConverterParameter=0}" />
                <RadioButton Style="{StaticResource SegmentStyle}" GroupName="Lang"
                             Content="{Binding Strings.LangJa}"
                             IsChecked="{Binding LanguageChoice, Converter={StaticResource EqBool}, ConverterParameter=1}" />
                <RadioButton Style="{StaticResource SegmentStyle}" GroupName="Lang"
                             Content="{Binding Strings.LangEn}"
                             IsChecked="{Binding LanguageChoice, Converter={StaticResource EqBool}, ConverterParameter=2}" />
            </StackPanel>
        </Grid>

        <!-- 注記（対象未選択時のヒント） -->
        <Border Grid.Row="2" Background="{DynamicResource Sic.NoteBg}" BorderBrush="{DynamicResource Sic.NoteBorder}"
                BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                Visibility="{Binding NoteText, Converter={StaticResource NonEmptyToVis}}">
            <TextBlock Text="{Binding NoteText}" Foreground="{DynamicResource Sic.NoteText}" TextWrapping="Wrap" />
        </Border>

        <!-- ファセット タグ クラウド -->
        <Border Grid.Row="3" Background="{DynamicResource Sic.Panel}" BorderBrush="{DynamicResource Sic.PanelBorder}"
                BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="{Binding Strings.StyleFacet}" DockPanel.Dock="Left"
                               Width="68" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,5,4,0" />
                    <ItemsControl ItemsSource="{Binding Styles}" ItemTemplate="{StaticResource ChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <DockPanel Margin="0,2">
                    <TextBlock Text="{Binding Strings.GenreFacet}" DockPanel.Dock="Left"
                               Width="68" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,5,4,0" />
                    <ItemsControl ItemsSource="{Binding Genres}" ItemTemplate="{StaticResource ChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <DockPanel Margin="0,2,0,0">
                    <TextBlock Text="{Binding Strings.ColorFacet}" DockPanel.Dock="Left"
                               Width="68" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,5,4,0" />
                    <ItemsControl ItemsSource="{Binding Colors}" ItemTemplate="{StaticResource ColorChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </DockPanel>

                <Button Content="{Binding Strings.ClearTags}" Command="{Binding ClearTagsCommand}"
                        HorizontalAlignment="Left" Margin="68,8,0,0" Padding="10,4" />
            </StackPanel>
        </Border>

        <!-- アイコン グリッド（行単位で仮想化。可視行のタイルのみデコード） -->
        <Border Grid.Row="4" Background="{DynamicResource Sic.Panel}" BorderBrush="{DynamicResource Sic.PanelBorder}"
                BorderThickness="1" CornerRadius="8">
            <ListBox x:Name="IconList" ItemsSource="{Binding Rows}"
                     BorderThickness="0" Background="Transparent" Padding="6"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ItemContainerStyle="{StaticResource RowContainerStyle}"
                     ItemTemplate="{StaticResource RowTemplate}"
                     SizeChanged="IconList_SizeChanged" />
        </Border>

        <!-- フッター -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <TextBlock Text="{Binding CountText}" VerticalAlignment="Center" Foreground="{DynamicResource Sic.TextSecondary}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding Strings.ResetToDefault}" Command="{Binding ResetCommand}"
                        Padding="12,6" Margin="0,0,8,0" />
                <Button Content="{Binding Strings.Custom}" Command="{Binding CustomCommand}"
                        Padding="12,6" Margin="0,0,8,0" />
                <Button x:Name="CancelButton" Content="{Binding Strings.Cancel}" Click="CancelButton_Click"
                        Padding="12,6" IsCancel="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
